/************************************************************
 * 📦 Inventario.gs – PRO v3.7 ULTRA-FINAL
 * Nova ✨ + Chipi
 * Correcciones definitivas:
 *  - Filtro LABORATORIO absoluto (A, B, C, D)
 *  - Relleno de código + producto estilo OSS
 *  - Costo = costo POR PRESENTACIÓN (no dividir)
 *  - Unidad real basada en descripción/presentación
 *  - Ordenar por PRODUCTO (columna B)
 ************************************************************/

function inv_normPresentacion_(str) {
  if (!str) return "";
  return String(str)
    .toLowerCase()
    .normalize("NFKC")
    .replace(/\bcaj[\.]?\b/g, "caja")
    .replace(/\bblist[\.]?\b/g, "blister")
    .replace(/\bsob[\.]?\b/g, "sobre")
    .replace(/\btab[\.]?\b/g, "tableta")
    .replace(/\bfras[\.]?\b/g, "frasco")
    .replace(/\s*x\s*/g, " x ")
    .replace(/\s+/g, " ")
    .trim();
}

/************************************************************
 * 🔢 Unidad REAL del producto
 ************************************************************/
function inv_getUnidadesReal_(pres, desc) {

  const clean = s => String(s || "").toLowerCase();
  const p = clean(pres);
  const d = clean(desc);

  // 1) DESCRIPCIÓN manda: "1 x N"
  let mDesc = d.match(/1\s*x\s*(\d+)/);
  if (mDesc) return Number(mDesc[1]);

  // 2) PRESENTACIÓN "1 x N"
  let mPres1 = p.match(/1\s*x\s*(\d+)/);
  if (mPres1) return Number(mPres1[1]);

  // 3) "x N" no líquidos
  let mDescX = d.match(/\bx\s*(\d+)(?!\s*(ml|g|kg|mg|l)\b)/);
  if (mDescX) return Number(mDescX[1]);

  let mPresX = p.match(/\bx\s*(\d+)(?!\s*(ml|g|kg|mg|l)\b)/);
  if (mPresX) return Number(mPresX[1]);

  // 4) Líquidos → SIEMPRE 1
  const liquidos = /(ml|g|kg|mg|l)\b/;
  if (liquidos.test(p) || liquidos.test(d)) return 1;

  // 5) Palabras clave → 1 unidad
  if (/unidad|tableta|ampolla|bote|lata|frasco/.test(p + " " + d)) return 1;

  return 1;
}

/************************************************************
 * 📥 DESCARGA + PROCESAMIENTO COMPLETO
 ************************************************************/
function descargarInventario() {

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sh = ss.getSheetByName(CFG.SHEET_INVENTARIO);
  if (!sh) sh = ss.insertSheet(CFG.SHEET_INVENTARIO);
  sh.clear();

  ss.toast("Descargando inventario...", "Estado", 3);

  const resp = sess_fetchWithCookie_(CFG.INVENTARIO_URL, "INV");
  if (!resp) return;

  // Convertir XLSX a Google Sheet temporal
  const blob = resp.getBlob().setName("Inventario.xlsx");
  const tempXlsx = DriveApp.createFile(blob);

  const converted = Drive.Files.insert(
    { title: "Inventario Temp", mimeType: MimeType.GOOGLE_SHEETS },
    tempXlsx,
    { convert: true }
  );

  const tempSS = SpreadsheetApp.openById(converted.id);
  const source = tempSS.getSheets()[0];

  let data = source.getDataRange().getValues();
  if (!data || data.length < 6) return;

  data.splice(0, 5); // remover cabecera OSS

  // columnas: código, producto, presentación, descripción, existencia, costo
  let cleaned = data.map(r => [
    r[0],  // Código
    r[1],  // Producto
    r[2],  // Presentación
    r[3],  // Descripción
    r[7],  // Existencia
    r[5],  // Costo por PRESENTACIÓN
  ]);

  /************************************************************
   * 🔥 FILTRO LABORATORIO ABSOLUTO (A, B, C, D)
   ************************************************************/
  cleaned = cleaned.filter(r => {
    return ![
      r[0], r[1], r[2], r[3]
    ]
      .join(" ")
      .trim()
      .toLowerCase()
      .startsWith("laboratorio:");
  });

  /************************************************************
   * 🔧 RELLENAR CÓDIGO + PRODUCTO (estilo OSS)
   ************************************************************/
  for (let i = 1; i < cleaned.length; i++) {
    if (!cleaned[i][1]) cleaned[i][1] = cleaned[i - 1][1]; // producto
    if (!cleaned[i][0]) cleaned[i][0] = cleaned[i - 1][0]; // código
  }

  /************************************************************
   * 🔄 Armar inventario final
   ************************************************************/
  const final = cleaned.map(r => {
    const codigo = String(r[0]).trim();
    const prod = String(r[1]).trim();
    const pres = inv_normPresentacion_(r[2]);
    const desc = inv_normPresentacion_(r[3]);

    const exis = Number(r[4]) || 0;
    const costoPres = Number(r[5]) || 0; // costo por presentación

    const unidades = inv_getUnidadesReal_(pres, desc);

    return [
      codigo,
      prod,
      pres,
      desc,
      exis,
      costoPres,   // NO dividir → queda como OSS
      unidades,
    ];
  });

  const header = [
    "Código",
    "Producto",
    "Presentación",
    "Descripción",
    "Existencia",
    "Costo por presentación",
    "Unidades / presentación"
  ];

  sh.getRange(1, 1, 1, header.length).setValues([header]);
  sh.getRange(2, 1, final.length, header.length).setValues(final);

  /************************************************************
   * ✔ ORDENAR POR PRODUCTO
   ************************************************************/
  sh.getRange(2, 1, final.length, header.length)
    .sort({ column: 2, ascending: true });

  // limpiar temporales
  DriveApp.getFileById(tempXlsx.getId()).setTrashed(true);
  DriveApp.getFileById(converted.id).setTrashed(true);

  ss.toast("✅ Inventario PRO actualizado", 5);
  irAHoja(CFG.SHEET.RESUMEN);
}

/************************************************************
 * 📦 INDEXADOR
 ************************************************************/
function inv_readInventarioIndex_() { //Nuevo 28/01

  const sh = SpreadsheetApp.getActiveSpreadsheet()
    .getSheetByName(CFG.SHEET_INVENTARIO);

  if (!sh) throw new Error("No existe la hoja Inventario.");
  if (sh.getLastRow() < 2) return {};

  const v = sh.getDataRange().getValues();
  const dict = {};

  for (let i = 1; i < v.length; i++) {
    const row = v[i];

    const producto = String(row[1]).trim();
    if (!producto) continue;

    const key = quitarTildes(producto.toLowerCase());
    if (!dict[key]) dict[key] = [];

    dict[key].push({
      presNorm: inv_normPresentacion_(row[2]),
      descNorm: inv_normPresentacion_(row[3]),
      existencia: Number(row[4]) || 0,
      conversionFactor: Number(row[6]) || 0, // unidades por presentación
      costoUnit: Number(row[5]) || 0         // costo por presentación
    });
  }

  return dict;
}

