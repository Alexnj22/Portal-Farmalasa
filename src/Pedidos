/*************** LÓGICA PARA REGLA 0 — SELECCIÓN INTELIGENTE DE PRESENTACIÓN ***************/
function seleccionarPresentacionRegla0(unidades, candidatos, TOL_PACK) {

  // Ordenamos de mayor a menor para evaluar primero CAJAS
  const desc = candidatos.slice().sort((a, b) => b.factor - a.factor);

  // 1️⃣ INTENTAR CAJA GRANDE (factor ≥ 10)
  for (const c of desc) {
    if (c.factor < 10) continue;

    const ratio = unidades / c.factor;
    const ent = Math.floor(ratio);
    const frac = ratio - ent;

    if (ratio >= 1) {
      return {
        factor: c.factor,
        label: c.label,
        packs: ent + (frac >= TOL_PACK ? 1 : 0)
      };
    }

    if (ratio >= TOL_PACK) {
      return { factor: c.factor, label: c.label, packs: 1 };
    }
  }

  // 2️⃣ INTENTAR BLISTER (factor entre 2 y 9)
  const blister = candidatos.find(c => c.factor >= 2 && c.factor < 10);

  if (blister) {
    const ratio = unidades / blister.factor;
    if (ratio >= 1) {
      return {
        factor: blister.factor,
        label: blister.label,
        packs: Math.floor(ratio)
      };
    }
    if (ratio >= TOL_PACK) {
      return { factor: blister.factor, label: blister.label, packs: 1 };
    }
  }

  // 3️⃣ UNIDADES
  const tieneUnidad = candidatos.some(c => c.factor === 1);
  if (tieneUnidad) return { factor: 1, label: "unidad", packs: unidades };

  if (unidades >= 2) return { factor: 1, label: "unidad", packs: unidades };

  return null;
}

