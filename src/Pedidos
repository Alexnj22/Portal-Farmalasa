/************************************************************
 * ✅ PERF: indexa agregados por hoja UNA sola vez
 * Devuelve: Map<sheetNameSolic, Map<"prod||lab", agg>>
 ************************************************************/
function pedido_indexarAgregadosPorHoja_(productRequests, inventarioDict) {
  const bySheet = new Map();

  for (const key in productRequests) {
    const [productoRaw] = key.split("||");
    const productoKey = quitarTildes(productoRaw.toLowerCase());
    const inventarioList = inventarioDict[productoKey] || [];
    const reqs = productRequests[key];

    for (let i = 0; i < reqs.length; i++) {
      const r = reqs[i];
      const sheetName = r.sheetName;
      if (!sheetName) continue;

      const lab = r.laboratorio || "";
      const prod = r.producto || productoRaw;
      const mapKey = prod + "||" + lab;

      let sheetMap = bySheet.get(sheetName);
      if (!sheetMap) {
        sheetMap = new Map();
        bySheet.set(sheetName, sheetMap);
      }

      let agg = sheetMap.get(mapKey);
      if (!agg) {
        agg = {
          laboratorio: lab,
          producto: prod,
          solicitado: 0,
          unidades: 0,        // unidades reales asignadas (allocated)
          inventarioList
        };
        sheetMap.set(mapKey, agg);
      }

      agg.solicitado += (Number(r.cantidad) || 0);
      agg.unidades += (Number(r.allocated) || 0);
    }
  }

  return bySheet;
}

/************************************************************
 * 🧹 ELIMINAR HOJAS NO NECESARIAS LUEGO DEL PROCESO
 ************************************************************/
function limpiarHojasDespuesPedido_(libro, hojasGeneradas) {

  const mantener = new Set([
    CFG.SHEET.RESUMEN.toLowerCase(),
    CFG.SHEET.REGLAS.toLowerCase(),
    CFG.SHEET.VENTAS_PERDIDAS.toLowerCase()
  ]);

  const todas = libro.getSheets();

  todas.forEach(sh => {
    const name = sh.getName().toLowerCase();

    // Hojas que siempre deben quedar
    if (mantener.has(name)) return;

    // Eliminar Inventario
    if (name === CFG.SHEET.INVENTARIO.toLowerCase()) {
      libro.deleteSheet(sh);
      return;
    }

    // Eliminar Solicitud - …
    if (name.startsWith("solicitud -")) {
      libro.deleteSheet(sh);
      return;
    }

    // Eliminar hojas de pedidos generados
    if (hojasGeneradas.includes(sh.getName())) {
      libro.deleteSheet(sh);
      return;
    }
  });
}

