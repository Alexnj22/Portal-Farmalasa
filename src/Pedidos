 ************************************************************/
function obtenerProductosSinExistenciaPorSucursal_(productRequests, sheetNameSolic) {
  const sinExist = [];

  for (const key in productRequests) {
    const reqs = productRequests[key];
    reqs.forEach(r => {
      if (r.sheetName !== sheetNameSolic) return;
      const unidades = Number(r.allocated) || 0;
      if (unidades <= 0) sinExist.push(`• ${r.laboratorio} – ${r.producto}`);
    });
  }

  return sinExist;
}


function sinExist_buildConsolidadoMap_(productRequests) {
  const map = new Map();

  for (const key in productRequests) {
    const reqs = productRequests[key];
    const [productoRaw] = key.split("||");

    reqs.forEach(r => {
      const allocated = Number(r.allocated) || 0;
      if (allocated > 0) return; // solo sin existencia

      const lab = r.laboratorio || "";
      const prod = r.producto || productoRaw;
      const sucursal = ((r.sheetName || "").split("-")[1] || "").trim() || "SIN SUCURSAL";
      const cant = Number(r.cantidad) || 0;

      const mapKey = prod + "||" + lab;
      let obj = map.get(mapKey);
      if (!obj) {
        obj = {
          laboratorio: lab,
          producto: prod,
          sucursales: new Map(),
          total: 0
        };
        map.set(mapKey, obj);
      }

      obj.total += cant;
      const prev = obj.sucursales.get(sucursal) || 0;
      obj.sucursales.set(sucursal, prev + cant);
    });
  }

  return map;
}

function pdf_enviarSinExistenciasPorSucursal_(sucursal, listaProductos) {
  try {
    if (!listaProductos || listaProductos.length === 0) return;

    // Carpeta temporal
    const tempFolder = DriveApp.createFolder("TEMP_SIN_EXIST_" + Date.now());

    // Crear documento
    const doc = DocumentApp.create(`Sin Existencias - ${sucursal}`);
    const body = doc.getBody();

    body.appendParagraph(`PRODUCTOS SIN EXISTENCIA`)
      .setHeading(DocumentApp.ParagraphHeading.HEADING1);
    body.appendParagraph(`Sucursal: ${sucursal}`);
    body.appendParagraph(
      `Fecha: ${Utilities.formatDate(new Date(),
        Session.getScriptTimeZone(),
        "dd/MM/yyyy HH:mm")}`
    );
    body.appendParagraph("");

    listaProductos.forEach(item => body.appendParagraph(item));

    body.appendParagraph("");
    body.appendParagraph(`Total de productos: ${listaProductos.length}`);

    doc.saveAndClose();

    // Obtener archivo del Doc
    const docFile = DriveApp.getFileById(doc.getId());
    tempFolder.addFile(docFile);  // mover a la carpeta temporal

    // Convertir a PDF
    const pdfBlob = docFile.getAs("application/pdf");
    pdfBlob.setName(`SinExistencias_${sucursal}.pdf`);

    // Enviar por Telegram (chat de la sucursal)
    const key = sucursal.trim().toLowerCase();
    const chatId = PEDIDOS_TG_CHAT_IDS[key] || TG_CHAT_ID;

    tg_sendPDF_(chatId, pdfBlob, `Productos sin existencia — ${sucursal}`);

    // Crear el PDF dentro del folder temporal y borrar ambos
    const pdfFile = tempFolder.createFile(pdfBlob);

    // Borrar el documento original y el PDF temporal
    docFile.setTrashed(true);
    pdfFile.setTrashed(true);

    // Borrar carpeta temporal
    tempFolder.setTrashed(true);

  } catch (err) {
    Logger.log("ERROR en pdf_enviarSinExistenciasPorSucursal_: " + err);
  }
}

function pdf_enviarSinExistenciasConsolidado_(sinExistMap) {
  try {
    if (!sinExistMap || sinExistMap.size === 0) {
      Logger.log("Consolidado: sin productos sin existencia.");
      return;
    }

    const totalProductos = sinExistMap.size; // ✅ ESTE es el total correcto (productos únicos sin existencia)

    // Sucursales dinámicas
    const sucursalesSet = new Set();
    sinExistMap.forEach(obj => {
      obj.sucursales.forEach((_, suc) => sucursalesSet.add(suc));
    });
    const sucursales = Array.from(sucursalesSet).sort();

    const ss = SpreadsheetApp.getActive();
    const sh = ss.insertSheet("TEMP_SIN_EXIST_GLOBAL_" + Date.now());

    const fechaTxt = Utilities.formatDate(
      new Date(),
      Session.getScriptTimeZone(),
      "dd/MM/yyyy HH:mm"
    );

    const header = ["Laboratorio", "Producto", ...sucursales, "Total"];
    const headerLen = header.length;

    // ================= ENCABEZADO (COMPACTO) =================
    // IMPORTANTE: merge SOLO 1 fila, nunca varias filas juntas.
    sh.getRange(1, 1).setValue("PRODUCTOS SIN EXISTENCIA – CONSOLIDADO");

    sh.getRange(2, 1).setValue("Fecha: " + fechaTxt);
    sh.getRange(3, 1).setValue("Total de productos sin existencia: " + totalProductos);
    sh.getRange(4, 1).setValue(""); // línea en blanco pequeña

    // Merge por fila (1 fila a la vez)
    sh.getRange(1, 1, 1, headerLen).merge();
    sh.getRange(2, 1, 1, headerLen).merge();
    sh.getRange(3, 1, 1, headerLen).merge();
    sh.getRange(4, 1, 1, headerLen).merge();

    // Formato header
    sh.getRange(1, 1)
      .setHorizontalAlignment("center")
      .setFontSize(14)
      .setFontWeight("bold");

    sh.getRange(2, 1, 2, 1)
      .setHorizontalAlignment("left")
      .setFontSize(10);

    // Alturas compactas
    sh.setRowHeight(1, 24);
    sh.setRowHeight(2, 18);
    sh.setRowHeight(3, 18);
    sh.setRowHeight(4, 10);

    // ================= TABLA =================
    const headerRow = 5;
    sh.getRange(headerRow, 1, 1, headerLen)
      .setValues([header])
      .setFontWeight("bold");

    // Orden
    const items = Array.from(sinExistMap.values()).sort((a, b) =>
      a.laboratorio === b.laboratorio
        ? String(a.producto).localeCompare(String(b.producto))
        : String(a.laboratorio).localeCompare(String(b.laboratorio))
    );

    let totalUnidades = 0;

    const data = items.map(obj => {
      const row = [obj.laboratorio, obj.producto];
      let total = 0;

      sucursales.forEach(suc => {
        const cant = obj.sucursales.get(suc) || 0;
        total += cant;
        row.push(cant);
      });

      row.push(total);
      totalUnidades += total;
      return row;
    });

    const startRow = headerRow + 1;
    if (data.length) {
      sh.getRange(startRow, 1, data.length, headerLen).setValues(data);
    }

    // Fila TOTAL UNIDADES (sumatoria solicitada)
