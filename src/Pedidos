function pedido_calcularRemanentes_(inventarioDict, productRequests) {
  const rem = new Map();

  // total inventario por productoKey
  for (const productoKey in inventarioDict) {
    const invList = inventarioDict[productoKey] || [];
    const totalInvUn = invList.reduce((sum, i) =>
      sum + (Number(i.conversionFactor) || 0) * (Number(i.existencia) || 0)
    , 0);
    rem.set(productoKey, totalInvUn);
  }

  // restar todo lo asignado globalmente (allocated está en UNIDADES)
  for (const key in productRequests) {
    const [productoRaw] = key.split("||");
    const productoKey = quitarTildes(String(productoRaw || "").toLowerCase());

    const reqs = productRequests[key] || [];
    const asignadoGlobal = reqs.reduce((sum, r) => sum + (Number(r.allocated) || 0), 0);

    const prev = rem.get(productoKey) || 0;
    rem.set(productoKey, Math.max(0, prev - asignadoGlobal));
  }

  return rem; // Map<productoKey, remanenteUnidades>
}

/************************************************************
 * 📑 Reglas.gs – Gestión de reglas por producto
 * Nova ✨ + Chipi — v3.5 (Header dinámico + FIX 302 + Optimizado)
 *
 * Funcionalidad:
 *  - Descargar listado de productos desde OSS
 *  - Detectar automáticamente las columnas PRODUCTO y LABORATORIO,
 *    aunque estén en otra fila o columna
 *  - Mantener hoja "Reglas" con:
 *        Laboratorio | Producto | Regla
 *  - Conservar reglas existentes (incluyendo "0") y agregar solo nuevos
 ************************************************************/


/**
 * 🔄 Función principal
 * Descarga productos_precios y sincroniza hoja "Reglas"
 */
function actualizarListadoProductosReglas() {

  const ss = SpreadsheetApp.getActiveSpreadsheet();

  // 1) Verificar hoja Reglas
  let shReglas = ss.getSheetByName(CFG.SHEET.REGLAS);
  if (!shReglas) {
    shReglas = ss.insertSheet(CFG.SHEET.REGLAS);
    shReglas.appendRow(["Laboratorio", "Producto", "Regla"]);
  }

  // 2) Cargar reglas existentes
  const existing = shReglas.getDataRange().getValues();
  const existingRows = [];
  const existingKeys = new Set();

  if (existing.length > 1) {
    for (let i = 1; i < existing.length; i++) {
      const [lab, prod, regla] = existing[i];
      const labStr  = String(lab  || "").trim();
      const prodStr = String(prod || "").trim();
      if (!prodStr) continue;

      const key = labStr + "||" + prodStr;

      // Mantener "0" correctamente
      let reglaStr = "";
      if (regla === 0) {
        reglaStr = "0";
      } else if (regla !== null && regla !== undefined && String(regla).trim() !== "") {
        reglaStr = String(regla).trim();
      } else {
        reglaStr = ""; // sin regla
      }

      existingKeys.add(key);
      existingRows.push([labStr, prodStr, reglaStr]);
    }
  }

  /************************************************************
   * 3) Descargar archivo productos_precios desde OSS
   ************************************************************/
  const url =
    CFG.OSS.PRODUCTOS_URL ||
    "https://clientesdte3.oss.com.sv/farma_salud/productos_precios_xls.php";

  let tempXls, converted;

  try {
    const resp = UrlFetchApp.fetch(url, {
      method: "get",
      followRedirects: true,
      muteHttpExceptions: true
    });

    const code = resp.getResponseCode();
    if (code !== 200 && code !== 302) {
      ss.toast("❌ Error al descargar productos_precios (código " + code + ")", "Reglas", 5);
      return;
    }

    const blob = resp.getBlob().setName("productos.xls");
    tempXls = DriveApp.createFile(blob);

    // Convertir a Google Sheets
    converted = Drive.Files.insert(
      { title: "ProductosTemp", mimeType: MimeType.GOOGLE_SHEETS },
      tempXls,
      { convert: true }
    );

    const tempSS = SpreadsheetApp.openById(converted.id);
    const source = tempSS.getSheets()[0];
    const data   = source.getDataRange().getValues();

    if (!data || data.length < 5) {
      ss.toast("⚠️ Archivo productos_precios vacío o incompleto", "Reglas", 5);
      return;
    }

    /************************************************************
     * 4) Encontrar dinámicamente la fila de encabezados
     ************************************************************/
    let headerRow = -1;
    let header = null;

    for (let i = 0; i < data.length; i++) {
      const row = data[i].map(x => String(x || "").toLowerCase().trim());

      const hasProducto =
        row.some(h => h.includes("descrip") || h.includes("producto"));

      const hasLab =
        row.some(h => h.includes("laboratorio"));

      if (hasProducto && hasLab) {
        headerRow = i;
        header = row;
        break;
      }
    }

    if (headerRow === -1) {
      ss.toast("⚠️ No se encontró encabezado válido (Descripción / Laboratorio)", "Reglas", 8);
      return;
    }

    // Localizar índice de columnas
    const idxProd = header.findIndex(h =>
      h.includes("descripcion") || h.includes("descrip") || h.includes("producto")
    );

    const idxLab = header.findIndex(h =>
      h.includes("laboratorio")
    );

    if (idxProd === -1 || idxLab === -1) {
      ss.toast("⚠️ No se encontraron columnas de Producto y Laboratorio", "Reglas", 8);
      return;
    }

    /************************************************************
     * 5) Recorrer productos desde headerRow+1
     ************************************************************/
    const nuevos = [];

    for (let i = headerRow + 1; i < data.length; i++) {
      const row = data[i];

      const producto    = String(row[idxProd] || "").trim();
      const laboratorio = String(row[idxLab] || "").trim();

      if (!producto) continue;

      const key = laboratorio + "||" + producto;

      if (!existingKeys.has(key)) {
        existingKeys.add(key);
        nuevos.push([laboratorio, producto, ""]);
      }
    }

    /************************************************************
     * 6) Actualizar hoja Reglas
     ************************************************************/
    shReglas.clearContents();
    shReglas.appendRow(["Laboratorio", "Producto", "Regla"]);

    const mapDedup = new Map();

    // Priorizar reglas existentes; si hubiera duplicados, se queda el primero que se cargó
    existingRows.forEach(r => mapDedup.set(r[0] + "||" + r[1], r));
    nuevos.forEach(r => {
      const k = r[0] + "||" + r[1];
      if (!mapDedup.has(k)) mapDedup.set(k, r);
    });

    const finalRows = Array.from(mapDedup.values());
    if (finalRows.length) {
      shReglas
        .getRange(2, 1, finalRows.length, 3)
        .setValues(finalRows)
        .sort([
          { column: 1, ascending: true },
          { column: 2, ascending: true }
        ]);
    }

    ss.toast(`✅ Reglas actualizadas (${nuevos.length} nuevos productos)`, "Reglas", 5);

  } finally {
    // Limpieza de temporales aunque falle algo arriba
    if (tempXls && tempXls.getId) {
      try { DriveApp.getFileById(tempXls.getId()).setTrashed(true); } catch (e) {}
    }
    if (converted && converted.id) {
      try { DriveApp.getFileById(converted.id).setTrashed(true); } catch (e) {}
    }
  }
}


