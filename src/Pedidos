  }

  // 🟢 Si no existe → descargar normalmente
  const url = CFG.OSS.BASE +
    `reporte_reposicion_xls.php?id_ubicacion=${suc.idUbicacion}`;
  sol_descargarYProcesarSucursal_(url, suc.nombre);
}
