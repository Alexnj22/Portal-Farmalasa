}

/************************************************************
 * 📥 Descargar + convertir + procesar UNA solicitud
 ************************************************************/
function sol_descargarYProcesarSucursal_(url, sucursalNombre) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheetName = `Solicitud - ${sucursalNombre}`;

  ss.toast(`Descargando ${sheetName}...`, "Estado", 3);
  logInfo && logInfo(`📥 Descargando solicitud para ${sucursalNombre} → ${url}`);

  const resp = sess_fetchWithCookie_(url, "SOL");
  if (!resp) {
    ss.toast("❌ Error solicitud", "Error", 5);
    logInfo && logInfo("❌ No se pudo obtener respuesta de OSS para solicitud.");
    return;
  }

  const blob = resp.getBlob().setName(`Solicitud_${sucursalNombre}.xlsx`);
  const temp = DriveApp.createFile(blob);

  const converted = Drive.Files.insert(
    { title: `${sheetName} - Temp`, mimeType: MimeType.GOOGLE_SHEETS },
    temp,
    { convert: true }
  );

  sol_procesarArchivo_(converted.id, sheetName);

  // Limpieza
  DriveApp.getFileById(temp.getId()).setTrashed(true);
  DriveApp.getFileById(converted.id).setTrashed(true);

  ss.toast(`✅ Solicitud lista: ${sheetName}`, "Ok", 3);
  irAHoja(CFG.SHEET.RESUMEN);
}

/************************************************************
 * 🧹 Normalizar archivo convertido → hoja estándar "Solicitud - X"
 ************************************************************/
function sol_procesarArchivo_(ssid, sheetName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  // Eliminar hoja previa
  const old = ss.getSheetByName(sheetName);
  if (old) ss.deleteSheet(old);

  const sh = ss.insertSheet(sheetName);
  const source = SpreadsheetApp.openById(ssid).getSheets()[0];

  let data = source.getDataRange().getValues();
  if (!data || data.length < 3) {
    logInfo && logInfo(`⚠️ Archivo de solicitud vacío para ${sheetName}`);
    return;
  }

  // 1) Quitar encabezados OSS
  data.splice(0, 2);

  // 2) Eliminar columnas 6, 5 y 4 (de derecha a izquierda)
  data.forEach(r => {
    r.splice(5, 1); // col 6
    r.splice(4, 1); // col 5
    r.splice(3, 1); // col 4
  });

  // Escribir datos limpios
  if (data.length) {
    sh.getRange(1, 1, data.length, data[0].length).setValues(data);
    sh.getDataRange().sort({ column: 4, ascending: false });
  }

  // 3) Remover filas desde el primer 0
  const n = sh.getLastRow();
  if (n) {
    const col4 = sh.getRange(1, 4, n).getValues();
    const firstZero = col4.findIndex(r => r[0] == 0 || r[0] === "0") + 1;

    if (firstZero > 0 && firstZero <= n) {
      sh.deleteRows(firstZero, n - firstZero + 1);
    }
  }

  // 4) Ordenar por laboratorio
  if (sh.getLastRow() > 1) {
    sh.getDataRange().sort({ column: 1, ascending: true });
  }

  sh.showSheet();
}

/************************************************************
 * 🔍 Leer todas las solicitudes → motor MatchingPro
 ************************************************************/
function sol_readAllRequests_(ss) { //nuevo 28/01
  const sheets = ss.getSheets()
    .filter(s => s.getName().toLowerCase().startsWith("solicitud -"));

  if (!sheets.length) return { requests: {}, tieneDetalle: false };

  const requests = {};
  let anyTieneDetalle = false;

  sheets.forEach(sh => {
    const data = sh.getDataRange().getValues();
    if (!data || !data.length) return;

    data.forEach(row => {
      const producto = (row[1] || "").toString().trim();
      if (!producto) return;

      const laboratorio = (row[0] || "").toString().trim();
      const pres = (row[2] || "").toString().trim();

      let det = "";
      let cantidad = 0;

      // ✅ si hay 5+ columnas, asumimos [lab,prod,pres,detalle,cant]
      if (row.length >= 5) {
        det = (row[3] || "").toString().trim();
        cantidad = Number(row[4]) || 0;
        anyTieneDetalle = true;
      } else {
        // ✅ formato final normal: [lab,prod,pres,cant]
        cantidad = Number(row[3]) || 0;
      }

      const presNorm = inv_normPresentacion_(det || pres);
      const key = producto + "||" + presNorm;

      if (!requests[key]) requests[key] = [];

      requests[key].push({
        sheetName: sh.getName(),
        laboratorio,
        producto,
        presentacion: pres,
        detalle: det,
        cantidad,
        allocated: 0,
      });
    });
  });

  return { requests, tieneDetalle: anyTieneDetalle };
}

