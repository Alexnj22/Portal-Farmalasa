function consolidarMinMaxPorProducto_(rows) {
  const map = new Map();

  rows.forEach(r => {
    const key =
      r.producto.trim().toLowerCase() +
      "||" +
      r.laboratorio.trim().toLowerCase();
    if (!map.has(key)) {
      map.set(key, {
        laboratorio: r.laboratorio,
        producto: r.producto,
        sucursal: r.sucursal,
        solicitado: r.solicitado,
        asignado: r.asignado,
        presentacion: r.presentacion,
        regla: r.regla,
        motivo: r.motivo
      });
    } else {
      const acc = map.get(key);

      // Regla más restrictiva (1 gana)
      acc.regla = Math.min(acc.regla, r.regla);

      // Motivos sin repetir
      if (!acc.motivo.includes(r.motivo)) {
        acc.motivo += " | " + r.motivo;
      }
    }
  });

  return Array.from(map.values());
}

function pdf_enviarMinMaxPorSucursal_(sucursal, rows) {
