  Logger.log("B dump: " + dump(b));

  // primer índice distinto
  const n = Math.max(a.length, b.length);
  for (let i = 0; i < n; i++) {
    if (a[i] !== b[i]) {
      Logger.log("DIFF en i=" + i + " A=" + (a[i] || "∅") + " B=" + (b[i] || "∅") +
        " codes: " + (a.charCodeAt(i) || "∅") + " vs " + (b.charCodeAt(i) || "∅"));
      break;
    }
  }
}

