/************************************************************
 * 🚀 Lanzador asíncrono genérico
 * Evita el cuadro negro de “Se está ejecutando una función…”
 *
 *   ejecutarAsync_("nombreFuncion", argumentoOpcional);
 *
 * Si no se pasa argumento, la función se llama sin parámetros.
 ************************************************************/
function ejecutarAsync_(funcName, arg) {
  const argExpr = (typeof arg === "undefined")
    ? "undefined"
    : JSON.stringify(arg);

  const html = HtmlService.createHtmlOutput(`
    <script>
      google.script.run
        .withSuccessHandler(function() {
          google.script.host.close();
        })
        [${JSON.stringify(funcName)}](${argExpr});
    </script>
  `).setWidth(10).setHeight(10);

  SpreadsheetApp.getUi().showModalDialog(html, " ");
}

/************************************************************
 * 🔁 MatchingPro – Motor inteligente Inventario vs Solicitudes
 * Chipi + Nova ✨ – Versión PRO v5.5 MULTI TURBO (FACTORES INVENTARIO)
 *
 * ✔ reqFactor se toma del INVENTARIO (columna "Unidades / presentación")
 * ✔ Fix: productos con factor 1 NO aplican reglas ni múltiplos
 * ✔ Basado SIEMPRE en unidades reales (r.allocated = unidades)
 * ✔ Regla 1: distribución por CAJAS (packs completos)
 * ✔ Si no es regla 1 → distribución proporcional por unidades
 * ✔ Múltiplos y blister aplicados solo cuando hay factor > 1
 * ✔ Inventario nunca se duplica ni se supera
 ************************************************************/

function match_asignarExistencias_(inventarioDict, productRequests) {

  const reglasCache = reglas_buildCache_(); //nuevo 28/01
  const reglasMap = reglasCache.map; //nuevo 28/01

  for (const key in productRequests) {

    const requests = productRequests[key];
    if (!requests || !requests.length) continue;

    const [productoRaw, presRaw] = key.split("||");
    const productoKey = quitarTildes(String(productoRaw || "").toLowerCase());
    const inventarioList = inventarioDict[productoKey] || [];

    // ✅ por producto (reset por cada key)
    let stepUnits = null;         // step final en UNIDADES reales
    let forceFirst = false;       // ✅ forzar 1 pack si step es 2..9 o 2b..9b
    let stepN = null;             // n del multiplo o blister
    let stepIsBlister = false;    // si el step viene de blister

    // -------------------------------------------------------
    // 1) INVENTARIO TOTAL EN UNIDADES + FACTOR MÁXIMO
    // -------------------------------------------------------
    let totalInvUnidades = 0;
    let maxFactor = 0;

    for (let i = 0; i < inventarioList.length; i++) {
      const factor = Number(inventarioList[i].conversionFactor) || 0;
      const existencia = Number(inventarioList[i].existencia) || 0;
      const unidades = factor * existencia;

      totalInvUnidades += unidades;
      if (factor > maxFactor) maxFactor = factor;
    }

    if (totalInvUnidades <= 0) {
      requests.forEach(r => r.allocated = 0);
      continue;
    }

    // -------------------------------------------------------
    // 2) FACTOR REAL DE LA PRESENTACIÓN SOLICITADA (reqFactor)
    // -------------------------------------------------------
    const presNorm = inv_normPresentacion_(presRaw);
    let reqFactor = 1;

    if (inventarioList.length) {
      let entrada = inventarioList.find(inv => inv.presNorm === presNorm);

      if (!entrada) {
        entrada = inventarioList.find(inv => inv.descNorm === presNorm);
      }

      if (!entrada) {
        entrada = inventarioList
          .filter(inv => Number(inv.conversionFactor) > 0)
          .sort((a, b) => a.conversionFactor - b.conversionFactor)[0];
      }

      reqFactor = (entrada && Number(entrada.conversionFactor) > 0)
        ? Number(entrada.conversionFactor)
        : 1;

    } else {
      reqFactor = inv_getUnidadesReal_(presRaw, productoRaw) || 1;
    }

    // -------------------------------------------------------
    // 3) SOLICITUDES EN UNIDADES REALES
    // -------------------------------------------------------
    let totalSolicitadoUn = 0;
    const solicitudes = [];

    for (let r of requests) {
      const solicitadoUn = (Number(r.cantidad) || 0) * reqFactor;
      solicitudes.push({ r, solicitadoUn });
      totalSolicitadoUn += solicitadoUn;
    }

    if (totalSolicitadoUn <= 0) {
      requests.forEach(r => r.allocated = 0);
      continue;
    }

    // -------------------------------------------------------
    // 4) maxFactor = 1 (sin cajas/blister), pero sí aplicar múltiplos
    // -------------------------------------------------------
    if (maxFactor === 1) {

      // 4.1 asignación base
      if (totalInvUnidades >= totalSolicitadoUn) {
        for (let s of solicitudes) s.r.allocated = s.solicitadoUn;
      } else {
        distribuirPorUnidadesProporcional_TURBO_(solicitudes, totalInvUnidades);
      }

      const soloCajas = reglas_esSoloCajas_Producto_fast_(productoRaw, reglasCache);

      if (!soloCajas) {

        // ✅ usar variables locales para no chocar con stepUnits global
        let stepUnitsLocal = null;
        let forceFirstLocal = false;
        let stepNLocal = null;

        for (let s of solicitudes) {
          const lab = String(s.r.laboratorio || "").trim();
          if (!lab) continue;

          const info = reglas_resolverParaProducto_(lab, productoRaw, reglasMap);
          if (!info) continue;

          // blister NO aplica si maxFactor=1 (no hay blister real)
          if (info.blister && !stepUnitsLocal) continue;

          // múltiplos normales sí aplican (sobre unidades)
          if (info.multiplo && !stepUnitsLocal) {
            stepUnitsLocal = info.multiplo * reqFactor;

            stepNLocal = Number(info.multiplo) || null;
            if (stepNLocal >= 2 && stepNLocal <= 9) forceFirstLocal = true;
          }
        }

        if (stepUnitsLocal && stepUnitsLocal > 1 && totalInvUnidades >= stepUnitsLocal) {
          ajustarMultiploGlobalSobreUnidades_(solicitudes, totalInvUnidades, stepUnitsLocal, forceFirstLocal);
        }
      }

      continue;
    }

    // -------------------------------------------------------
    // 5) DETECTAR REGLAS (solo si hay presentaciones con factor > 1)
    // -------------------------------------------------------
    const soloCajas = reglas_esSoloCajas_Producto_fast_(productoRaw, reglasCache);

    // Detectar primera combinación lab+producto con reglas
    for (let s of solicitudes) {
      const lab = String(s.r.laboratorio || "").trim();
      if (!lab) continue;

      const info = reglas_resolverParaProducto_(lab, productoRaw, reglasMap);
      if (!info) continue;

      // 5.1 BLISTER (2b..9b)
      if (info.blister && !stepUnits) {

        let blisterFactor = null;

        for (let inv of inventarioList) {
          const etiqueta = String(inv.presNorm || inv.descNorm || "").toLowerCase();
          const factor = Number(inv.conversionFactor) || 0;
          if (!factor) continue;

          if (etiqueta.includes("blis") || etiqueta.includes("sobre")) {
            blisterFactor = factor;
            break;
          }
        }

        if (!blisterFactor) blisterFactor = reqFactor || 1;

        stepUnits = info.blister * blisterFactor;

        // ✅ bandera forzar 1 pack si n=2..9
        stepN = Number(info.blister) || null;
        stepIsBlister = true;
        if (stepN >= 2 && stepN <= 9) forceFirst = true;

        continue; // blister tiene prioridad
      }

      // 5.2 MÚLTIPLO NORMAL (2..9 fuerza, otros con TOL)
      if (info.multiplo && !stepUnits) {
        stepUnits = info.multiplo * reqFactor;

        // ✅ NUEVO: activar forceFirst para 2..9
        stepN = Number(info.multiplo) || null;
        stepIsBlister = false;
        if (stepN >= 2 && stepN <= 9) forceFirst = true;
      }
    }

    if (stepUnits !== null && stepUnits <= 1) {
      stepUnits = null;
      forceFirst = false;
      stepN = null;
      stepIsBlister = false;
    }

    // -------------------------------------------------------
    // 6) CASO A — SOLO CAJAS (Regla 1)
    // -------------------------------------------------------
    if (soloCajas) {
      const packFactor = maxFactor || reqFactor || 1;
      let packsDisponibles = (totalInvUnidades / packFactor) | 0;

      if (packsDisponibles <= 0) {
        solicitudes.forEach(s => s.r.allocated = 0);
        continue;
      }

      const demandas = solicitudes.map(s => ({
        r: s.r,
        solicitadoUn: s.solicitadoUn,
        cajasNecesarias: Math.ceil(s.solicitadoUn / packFactor),
        cajasAsignadas: 0
      }));

      demandas.sort((a, b) => b.solicitadoUn - a.solicitadoUn);

      for (let d of demandas) {
        if (packsDisponibles <= 0 || d.cajasNecesarias <= 0) break;
        const asignar = Math.min(d.cajasNecesarias, packsDisponibles);
        d.cajasAsignadas = asignar;
        packsDisponibles -= asignar;
      }

      demandas.forEach(d => {
        d.r.allocated = d.cajasAsignadas * packFactor;
      });

      continue;
    }

    // -------------------------------------------------------
    // 7) CASO B — SIN REGLA 1 (proporcional por unidades)
    // -------------------------------------------------------
    if (totalInvUnidades >= totalSolicitadoUn) {
      solicitudes.forEach(s => s.r.allocated = s.solicitadoUn);
    } else {
      distribuirPorUnidadesProporcional_TURBO_(solicitudes, totalInvUnidades);
    }

    // -------------------------------------------------------
    // 8) APLICAR MÚLTIPLOS GLOBALES
    // -------------------------------------------------------
    if (stepUnits && stepUnits > 1) {
      ajustarMultiploGlobalSobreUnidades_(solicitudes, totalInvUnidades, stepUnits, forceFirst);
    }
  }
}


/************************************************************
 * ⚡ Proporcional TURBO
 ************************************************************/
function distribuirPorUnidadesProporcional_TURBO_(solicitudes, totalInvUnidades) {
  let totalSolicitado = solicitudes.reduce((t, s) => t + s.solicitadoUn, 0);
  if (totalSolicitado <= 0 || totalInvUnidades <= 0) {
    solicitudes.forEach(s => s.r.allocated = 0);
    return;
  }

  const n = solicitudes.length;
  const asignado = new Array(n).fill(0);
  let sumAsign = 0;

  for (let i = 0; i < n; i++) {
    const p = solicitudes[i].solicitadoUn / totalSolicitado;
    asignado[i] = (p * totalInvUnidades) | 0;
    sumAsign += asignado[i];
  }

  let rem = totalInvUnidades - sumAsign;

  // Repartir el resto a quienes tienen más saldo pendiente
  while (rem > 0) {
    let idx = -1;
    let bestSaldo = 0;

    for (let i = 0; i < n; i++) {
      const s = solicitudes[i];
      const saldo = s.solicitadoUn - asignado[i];
      if (saldo > bestSaldo) {
        bestSaldo = saldo;
        idx = i;
      }
    }

    if (idx === -1) break;
    asignado[idx]++;
    rem--;
  }

  for (let i = 0; i < n; i++) {
    solicitudes[i].r.allocated = asignado[i];
  }
}


/************************************************************
 * ⚡ Ajuste de múltiplos globales (usa stepUnits directamente)
 ************************************************************/
function ajustarMultiploGlobalSobreUnidades_(solicitudes, totalInvUnidades, stepUnits, forceFirst) {
  const step = stepUnits;
  if (!step || step <= 1) return;
  if (totalInvUnidades < step) return;

  const TOL = 0.40;

  const items = solicitudes
    .map((s, i) => ({
      idx: i,
      solicitadoUn: s.solicitadoUn,
      base: Number(s.r.allocated) || 0,
      packs: 0,
      units: 0
    }))
    .filter(x => x.base > 0);

  if (!items.length) return;

  let totalSuggested = 0;

  // 1) Calcular packs sugeridos por sucursal
  for (let it of items) {
    const ratio = it.base / step;
    const ent = Math.floor(ratio);
    const frac = ratio - ent;

    let packs;
    if (ratio < 1) {
      packs = (forceFirst && it.base > 0) ? 1 : (ratio >= TOL ? 1 : 0);
    } else {
      packs = ent + (frac >= TOL ? 1 : 0);
    }

    if (packs < 0) packs = 0;

    it.packs = packs;
    it.units = packs * step;
    totalSuggested += it.units;
  }

  // 2) Si nos pasamos del inventario, recortar desde los que más piden
  if (totalSuggested > totalInvUnidades) {
    items.sort((a, b) => b.solicitadoUn - a.solicitadoUn);

    let exceso = totalSuggested - totalInvUnidades;

    while (exceso > 0) {
      let cambio = false;

      for (let it of items) {
        if (exceso <= 0) break;
        if (it.packs <= 0) continue;

        it.packs--;
        it.units -= step;
        exceso -= step;
        if (exceso < 0) exceso = 0;
        cambio = true;
      }

      if (!cambio) break;
    }
  }

  // 3) Aplicar resultado final
  for (let it of items) {
    const finalUnits = it.units;
    solicitudes[it.idx].r.allocated = finalUnits < 0 ? 0 : finalUnits;
  }
}


/************************************************************
 * ⚡ Solo cajas (Regla 1)
 ************************************************************/

function reglas_esSoloCajas_Producto_fast_(productoRaw, reglasCache) { // Nuevo 28/01
  const prod = String(productoRaw || "").trim();
  return reglasCache && reglasCache.soloCajasSet
    ? reglasCache.soloCajasSet.has(quitarTildes(prod.toLowerCase()))
    : false;
}

function reglas_esSoloCajas_Producto_cached_(productoRaw, reglasMap) {
  const prod = String(productoRaw || "").trim();
  for (const k of reglasMap.keys()) {
    if (k.endsWith("||" + prod)) {
      const reglas = reglasMap.get(k) || [];
      return reglas.includes(1);
    }
  }
  return false;
}



