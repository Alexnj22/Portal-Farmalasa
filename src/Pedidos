/************************************************************
 * ♻️ APLICAR MÚLTIPLOS SOBRE PACKS — FASE B
 *
 * Reglas:
 *  - 40% aplica a TODO
 *  - EXCEPCIÓN: múltiplos 2–9 → siempre enviar múltiplo
 *    si inventario lo permite
 *  - Nb SIEMPRE respeta 40%
 ************************************************************/
function reglas_aplicarMultiploSobrePacks_(packsBase, step, packFactor, inventarioTotalUnidades, isBlisterRule) { //Nuevo 28/01

 const TOL = 0.40;
  const isNb = !!isBlisterRule; // nuevo 28/01

  if (packsBase <= 0 || step <= 0 || packFactor <= 0) {
    return { packs: 0, override: true, motivo: "Datos inválidos para aplicar regla" };
  }

  const unidadesMultiplo = step * packFactor;
  const inventarioPermiteMultiplo =
    packFactor === 1
      ? inventarioTotalUnidades >= step
      : inventarioTotalUnidades >= unidadesMultiplo;

  // ✅ Nb (blíster): SIEMPRE respeta 40% y NO usa excepción 2–9
  if (isBlisterRule) {
    const ratio = packsBase / step;
    if (ratio < TOL) {
      return { packs: 0, override: true, motivo: "Nb no cumple 40%" };
    }

    const q = Math.floor(packsBase / step);
    const rem = packsBase - q * step;
    const finalPacks = rem >= step * TOL ? (q + 1) * step : q * step;

    // no exceder inventario real (si packFactor>1)
    if (packFactor > 1 && finalPacks * packFactor > inventarioTotalUnidades) {
      const maxPacks = Math.floor(inventarioTotalUnidades / packFactor);
      return { packs: maxPacks, override: false, motivo: "Nb ajustado a inventario" };
    }

    return { packs: Math.max(0, finalPacks), override: false, motivo: "Nb aplicado (40%)" };
  }

  // ✅ Múltiplos 2–9: excepción (si inventario lo permite)
  if (step >= 2 && step <= 9) {

    if (!inventarioPermiteMultiplo) {
      return {
        packs: packsBase,
        override: false,
        motivo: "Inventario insuficiente para múltiplo, se permite parcial"
      };
    }

    if (packsBase < step * TOL) {
      return {
        packs: step,
        override: false,
        motivo: `Múltiplo ${step}: bajo 40% pero se envía primer múltiplo`
      };
    }

    const q = Math.floor(packsBase / step);
    const rem = packsBase - q * step;

    let finalPacks = rem >= step * TOL ? (q + 1) * step : q * step;
    if (finalPacks <= 0) finalPacks = step;

    // no exceder inventario
    if (packFactor === 1 && finalPacks > inventarioTotalUnidades) {
      return { packs: inventarioTotalUnidades, override: false, motivo: "Ajustado a inventario disponible" };
    }
    if (packFactor > 1 && finalPacks * packFactor > inventarioTotalUnidades) {
      const maxPacks = Math.floor(inventarioTotalUnidades / packFactor);
      return { packs: maxPacks, override: false, motivo: "Ajustado a inventario disponible" };
    }

    return {
      packs: finalPacks,
      override: false,
      motivo: `Múltiplo ${step}: redondeo normal aplicado`
    };
  }

  // ✅ Múltiplos ≥10: 40% obligatorio
  const ratio = packsBase / step;

  if (ratio < TOL && inventarioPermiteMultiplo) {
    return { packs: 0, override: true, motivo: `Regla ${step}: no cumple 40%` };
  }

  if (!inventarioPermiteMultiplo) {
    return { packs: packsBase, override: false, motivo: "Inventario insuficiente para múltiplo" };
  }

  const q = Math.floor(packsBase / step);
  const rem = packsBase - q * step;

  let finalPacks = rem >= step * TOL ? (q + 1) * step : q * step;
  if (finalPacks <= 0) finalPacks = step;

  // no exceder inventario
  if (packFactor > 1 && finalPacks * packFactor > inventarioTotalUnidades) {
    const maxPacks = Math.floor(inventarioTotalUnidades / packFactor);
    return { packs: maxPacks, override: false, motivo: "Ajustado a inventario disponible" };
  }

  return { packs: finalPacks, override: false, motivo: "Múltiplo aplicado correctamente" };
}

