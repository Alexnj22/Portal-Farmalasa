function reglas_cargarMapa_() {
  const sh = SpreadsheetApp.getActive().getSheetByName(CFG.SHEET.REGLAS);
  const map = new Map();
  if (!sh) return map;

  const data = sh.getDataRange().getValues();

  for (let i = 1; i < data.length; i++) {
    const [lab, prod, reglaRaw] = data[i];
    if (!prod) continue;

    const key =
      quitarTildes(String(lab || '').toLowerCase().trim()) +
      '||' +
      quitarTildes(String(prod || '').toLowerCase().trim());
    let raw = "";
    if (reglaRaw !== null && reglaRaw !== undefined) raw = String(reglaRaw).trim();

    if (raw === "") {
      map.set(key, []);
      continue;
    }

    const reglasList = raw.replace(/\s+/g, '').split(',');
    map.set(key, reglasList);
  }

  return map;
}

function reglas_buildCache_() { // nuevo 28/01
  const map = reglas_cargarMapa_();

  // set con productos que tienen regla 1 (solo cajas)
  const soloCajasSet = new Set();

