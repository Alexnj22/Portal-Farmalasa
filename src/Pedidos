/** Quita acentos y normaliza texto para indexaciones */
function quitarTildes(str) {
  if (str == null) return "";

  // Convertimos SIEMPRE a string antes de usar normalize
  const s = String(str);

  return s
    .normalize("NFD")               // separa letras y tildes
    .replace(/[\u0300-\u036f]/g, "")// elimina los diacríticos
    .replace(/ñ/g, "n")             // opcional: normaliza ñ
    .replace(/Ñ/g, "N");
}

/** Navegar hacia una hoja */
function irAHoja(nombre) {
  const sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(nombre);
  if (sh) SpreadsheetApp.setActiveSheet(sh);
}

/** Convierte nombre "Salud 1" -> código "S1" */
function nombreToCode(nombre) {
  const clean = quitarTildes(nombre).replace(/\s+/g, "");
  if (/lapopular/.test(clean)) return "LP";
  const m = clean.match(/salud(\d+)/);
  return m ? `S${m[1]}` : clean.substring(0,2).toUpperCase();
}

/************************************************************
 * 🧪 Presentaciones – Normalización 
 ************************************************************/

/**
 * Normaliza presentación: 
 * - convierte 1x6 a "1x6"
 * - convierte "caja x 6" a "1x6"
 * - convierte "blister 10" a "1x10"
 */
function normalizarPresentacion(p) {
  if (p == null) return "";        // tolera null/undefined

  let t = String(p);               // 🔥 FIX CRÍTICO: siempre string

  t = quitarTildes(t)
    .toLowerCase()
    .normalize("NFKC")              // 🔥 FIX: ahora está seguro
    .replace(/caja|blister|unidad|frasco|botella/gi, "")
    .replace(/x/gi, "x")
    .replace(/\s+/g, "")
    .trim();

  // Si viene solo como "10" → convertir a "1x10"
  if (/^\d+$/.test(t)) return `1x${t}`;

  // Formato estándar 1xN
  const m = t.match(/(\d+)x(\d+)/);
  if (m) return `${m[1]}x${m[2]}`;

  return t;
}
/************************************************************
 * 📦 Extraer unidades por presentación 
 ************************************************************/
function extraerUnidadesPresentacion(p) {
  p = normalizarPresentacion(p);
  const m = p.match(/(\d+)x(\d+)/);
  if (!m) return 1; 
  return Number(m[1]) * Number(m[2]);
}

/************************************************************
 * 🔄 Comparación entre presentaciones equivalentes
 ************************************************************/
function presentacionesEquivalentes(a, b) {
  a = normalizarPresentacion(a);
  b = normalizarPresentacion(b);
  if (!a || !b) return false;
  return extraerUnidadesPresentacion(a) === extraerUnidadesPresentacion(b);
}


function formatearTiempo(mins) {
  if (!mins || mins <= 0) return "0 min";
  const h = Math.floor(mins / 60);
  const m = Math.round(mins % 60);
  if (h > 0) return `${h}h ${m}min`;
  return `${m} min`;
}/************************************************************
 * 🔍 EXTRAER UNIDADES — Módulo requerido por MatchingPro
 * Devuelve:
 *    { factor: N, unidadBase: "unidad" }
 * Ej:
 *    "caja x 10" → factor 10
 *    "1x1"       → factor 1
 *    "blister x 6" → 6
 *    "frasco 120 ml" → 1
 ************************************************************/
function inv_extractUnits_(pres) {
  if (!pres) return { factor: 1, unidadBase: "unidad" };

  const p = String(pres).toLowerCase().trim();

  // -----------------------------
  // 1) Líquidos → siempre 1 unidad
  // -----------------------------
  if (/ml|cc|líquido|liquido/.test(p)) {
    return { factor: 1, unidadBase: "unidad" };
  }

  // -----------------------------
  // 2) Formato tipo "caja x 10"
  // -----------------------------
  let m = p.match(/x\s*(\d+)/);
  if (m) {
    return {
      factor: Number(m[1]),
      unidadBase: "unidad",
    };
  }

  // -----------------------------
  // 3) Formato "10" suelto → interpretarlo como 1x10
  // -----------------------------
  if (/^\d+$/.test(p)) {
    return {
      factor: Number(p),
      unidadBase: "unidad",
    };
  }

  // -----------------------------
  // 4) Formato tipo "10tab", "10tb", etc.
  // -----------------------------
  m = p.match(/(\d+)\s*(tab|tb|tableta|caps?)/);
  if (m) {
    return {
      factor: Number(m[1]),
      unidadBase: "unidad",
    };
  }

  // -----------------------------
  // 5) Último recurso → 1 unidad
  // -----------------------------
  return { factor: 1, unidadBase: "unidad" };
}

